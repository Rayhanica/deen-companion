NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase is optional for guest mode. Add these to enable auth and cloud sync.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-side key for external Hadith API fallback.
# Keep this private and do not expose it as NEXT_PUBLIC_.
HADITH_API_KEY=

# Optional AI companion. Without this, the app uses local content-based guidance.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Optional authenticated Quran Foundation Content API access.
# Without these values, every ayah still receives the bundled contextual study guide.
QURAN_FOUNDATION_CLIENT_ID=
QURAN_FOUNDATION_ACCESS_TOKEN=
